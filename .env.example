# JobSignal — example environment names only (no real secrets).
# Copy to .env locally; never commit .env.

# Core
# In staging/production, CACHE_URL becomes required (see backend/core/env.py).
NODE_ENV=development
APP_PUBLIC_BASE_URL=http://localhost:3000
API_PUBLIC_BASE_URL=http://localhost:8080

# Tenant identification (example header name; choose one pattern for prod)
TENANT_ID_HEADER=x-tenant-id

# Search / verification (wire to your chosen provider(s))
SEARCH_API_KEY=
SEARCH_API_ENDPOINT=
# SerpAPI (organic links) — also accepts SEARCH_API_KEY for the same adapter
SERPAPI_API_KEY=
# Optional: offline search stub for demos/CI (JSON with urls / by_query_substring)
JOBSIGNAL_SEARCH_FIXTURE_PATH=data_sources/fixtures/search_fixtures.json
# Provider order: serpapi, fixture (comma-separated)
SEARCH_PROVIDER_ORDER=serpapi,fixture

# Similar jobs (max 3); RECOMMENDATIONS_ENABLED=0 keeps responses identical to pre–Sprint 6 unless client sends recommendations_enabled=true
RECOMMENDATIONS_ENABLED=0
RECOMMENDATIONS_MAX=3
RECOMMENDATIONS_CANDIDATE_POOL=8

# Optional: reasoning layer (if used; not a source of truth)
ENABLE_LLM_SIGNALS=0

# Optional: screenshot / vision extraction (multipart field job_image on POST /v1/verify)
ENABLE_IMAGE_VERIFY=0
IMAGE_MAX_BYTES=5242880

# Fireworks (recommended): OpenAI-compatible API for runtime inference
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_MODEL=accounts/fireworks/models/kimi-k2p5
# Vision model for screenshots (defaults to FIREWORKS_MODEL then kimi-k2p5 if unset)
FIREWORKS_VISION_MODEL=accounts/fireworks/models/kimi-k2p5
FIREWORKS_TIMEOUT_S=20

# Back-compat (optional): if you use a different LLM provider, set LLM_API_KEY instead of FIREWORKS_API_KEY.
LLM_API_KEY=
LLM_MODEL_VERSION=

# Cache (e.g. Redis)
CACHE_URL=
CACHE_DEFAULT_TTL_DAYS=14

# Source / pipeline versioning (bump when signals or normalization change)
SOURCE_PIPELINE_VERSION=1
# Bump when rule thresholds or verdict gates change (cache invalidation)
SCORER_VERSION=1

# Fetch safety (primary job URL GET when ENABLE_JOB_FETCH=1)
ENABLE_JOB_FETCH=0
FETCH_MAX_BYTES=2097152
FETCH_MAX_REDIRECTS=5

# Rate limiting
RATE_LIMIT_PER_MINUTE_IP=30
RATE_LIMIT_PER_MINUTE_TENANT=120

# Observability
LOG_LEVEL=info
SENTRY_DSN=
