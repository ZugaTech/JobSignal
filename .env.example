# JobSignal environment contract (safe placeholders only)

# Vite/React (optional): API origin when the UI is served separately — no trailing slash. Leave empty if API is same-origin.
VITE_API_BASE=

# Runtime
NODE_ENV=development
PORT=8080
ALLOWED_ORIGINS=*
LOG_LEVEL=info
# When 1/true, /ready performs live Fireworks + Serper probes. Leave false in production to avoid burning provider quota on health checks.
PROBE_PROVIDERS_ON_READY=0

# Pipeline versions
SOURCE_PIPELINE_VERSION=1
SCORER_VERSION=1

# Cache
CACHE_URL=
CACHE_DEFAULT_TTL_DAYS=14
# Multi-instance (e.g. Railway with NODE_ENV=development): set to 1 so /ready fails until CACHE_URL is set.
JOBSIGNAL_REQUIRE_SHARED_CACHE=0

# Safety and limits
MAX_UPLOAD_BYTES=5242880
# Legacy alias still accepted by image ingest helpers.
IMAGE_MAX_BYTES=5242880
RATE_LIMIT_REQUESTS_PER_MINUTE=20
RATE_LIMIT_BURST=5
ENABLE_JOB_FETCH=0
FETCH_MAX_BYTES=2097152
FETCH_BODY_TEXT_MAX_CHARS=16000
FETCH_MAX_REDIRECTS=5

# Search — Serper.dev primary (POST + X-API-KEY); SerpApi optional fallback (GET search.json + api_key)
SERPER_API_KEY=
SERPAPI_API_KEY=
SERPAPI_SEARCH_ENDPOINT=https://serpapi.com/search.json
SEARCH_API_KEY=
SEARCH_API_ENDPOINT=https://google.serper.dev/search
SEARCH_TIMEOUT_S=10
SEARCH_RETRY_COUNT=2
SEARCH_RATE_LIMIT_PER_MINUTE=60
# Separate Serper POST budgets so evidence searches are not starved by reputation queries
SEARCH_MAX_CALLS_EVIDENCE=8
SEARCH_MAX_CALLS_REPUTATION=8
SEARCH_MAX_CALLS_RECOMMENDATIONS=8

# Feature flags
RECOMMENDATIONS_ENABLED=0
RECOMMENDATIONS_MAX=3
RECOMMENDATIONS_CANDIDATE_POOL=8
RECOMMENDATIONS_MIN_VERIFY_SCORE=70
ENABLE_LLM_SIGNALS=0
ENABLE_IMAGE_VERIFY=0

# Fireworks / LLM
FIREWORKS_API_KEY=
LLM_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_MODEL=accounts/fireworks/models/kimi-k2-instruct-0905
FIREWORKS_VISION_MODEL=accounts/fireworks/models/kimi-k2-instruct-0905
FIREWORKS_TIMEOUT_S=10
FIREWORKS_RETRY_COUNT=2

# Demo / fixture guardrails (must stay disabled in production/staging)
DEMO_MODE=0
OFFLINE_MODE=0
USE_FIXTURES=0
USE_SEARCH_FIXTURES=0
JOBSIGNAL_SEARCH_FIXTURE_PATH=
