# JobSignal — example environment names only (no real secrets).
# Copy to .env locally; never commit .env.

# Core
NODE_ENV=development
APP_PUBLIC_BASE_URL=http://localhost:3000
API_PUBLIC_BASE_URL=http://localhost:8080

# Tenant identification (example header name; choose one pattern for prod)
TENANT_ID_HEADER=x-tenant-id

# Search / verification (wire to your chosen provider(s))
SEARCH_API_KEY=
SEARCH_API_ENDPOINT=

# Optional: reasoning layer (if used; not a source of truth)
LLM_API_KEY=
LLM_MODEL_VERSION=

# Cache (e.g. Redis)
CACHE_URL=
CACHE_DEFAULT_TTL_DAYS=14

# Source / pipeline versioning (bump when signals or normalization change)
SOURCE_PIPELINE_VERSION=1
# Bump when rule thresholds or verdict gates change (cache invalidation)
SCORER_VERSION=1

# Fetch safety
FETCH_MAX_BYTES=2097152
FETCH_MAX_REDIRECTS=5

# Rate limiting
RATE_LIMIT_PER_MINUTE_IP=30
RATE_LIMIT_PER_MINUTE_TENANT=120

# Observability
LOG_LEVEL=info
SENTRY_DSN=
